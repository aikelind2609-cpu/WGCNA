# Venn diagram
library(VennDiagram)
# loading WGCNA list
# setwd("~/Downloads/final/ENVMT")
hub_expr <- read.csv("hubExpr.csv", row.names = 1)
hub_genes <- colnames(hub_expr)
head(hub_genes)
length(hub_genes)
# loading DEG list
deg_genes <- deg_results[deg_results$adj.P.Val < 0.05& abs(deg_results$logFC) > 1, ]
deg_gene_names <- rownames(deg_genes)

# Plot Venn
venn.plot <- venn.diagram(
  x = list(
    "WGCNA Hub Genes" = hub_genes,
    "Significant DEGs" = deg_gene_names
  ),
  filename = "Venn_Hub_vs_DEG.png",
  fill = c("cornflowerblue", "tomato"),
  alpha = 0.5,
  cex = 2,
  cat.cex = 1.5,
  cat.pos = 0,
  cat.dist = 0.05,
  main = "Overlap: Hub Genes vs DEGs"
)

# Save overlap genes
common_genes <- intersect(hub_genes, deg_gene_names)
write.csv(common_genes, "Overlapping_Hub_DEGs.csv")


