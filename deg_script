# Normalization
# Load necessary library
library(readr)
# Load without setting row names
data_raw <- read.csv("GSE282430_expression.csv", check.names = FALSE, stringsAsFactors = FALSE)
head(data_raw[, 1:5])
colnames(data_raw)[1:5]


# Remove rows with missing gene names
data_clean <- data_raw[!is.na(data_raw[,1]) & data_raw[,1] != "", ]
# Now set gene names as rownames
rownames(data_clean) <- data_clean[,1]
expression_data <- data_clean[,-1]
dim(expression_data)
head(expression_data[,1:5])

# making expression data completely numeric
expression_data_numeric <- as.data.frame(lapply(expression_data, function(x) as.numeric(as.character(x))))
rownames(expression_data_numeric) <- rownames(expression_data)
# Check structure
str(expression_data_numeric[, 1:5])
summary(expression_data_numeric[, 1:5])
boxplot(expression_data_numeric, las = 2, main = "Expression Distribution")

# fixing
expression_data_numeric <- expression_data_numeric[, !(colnames(expression_data_numeric) %in% c("chromosome", "start", "end", "gene", "gene_type"))]
dim(expression_data_numeric)
colnames(expression_data_numeric)
# Boxplot again
boxplot(expression_data_numeric, las = 2, main = "Expression Distribution (Corrected)")

#library(limma)
library(limma)
group <- factor(c(rep("Tumor", 22), rep("Normal", 6))) 
colnames(expression_data_numeric) 
# Creating design matrix
design <- model.matrix(~0 + group)
colnames(design) <- levels(group)
# Fit linear model
fit <- lmFit(expression_data_numeric, design)
# error detected

# fixing dim
ncol(expression_data_numeric)
colnames(expression_data_numeric)

# making dim of exp and desg same
samples <- colnames(expression_data_numeric)
group <- ifelse(grepl("^hT", samples), "Tumor", "Normal")
group <- factor(group)
length(group)
ncol(expression_data_numeric)
# Creating design matrix again
design <- model.matrix(~0 + group)
colnames(design) <- levels(group)

library(limma)

fit <- lmFit(expression_data_numeric, design)
contrast_matrix <- makeContrasts(Tumor - Normal, levels = design)
fit2 <- contrasts.fit(fit, contrast_matrix)
fit2 <- eBayes(fit2)

deg_results <- topTable(fit2, adjust = "fdr", number = Inf)
write.csv(deg_results, "DEG_results_Tumor_vs_Normal.csv")

volcanoplot(fit2, highlight = 20, names = rownames(expression_data_numeric), main = "Tumor vs Normal")
# plotted only top genes because of overlap
top_genes <- head(deg_results[order(deg_results$adj.P.Val), ], 10)
volcanoplot(fit2, highlight = 0, names = rownames(expression_data_numeric), main = "Tumor vs Normal")
with(top_genes, text(logFC, -log10(P.Value), labels = rownames(top_genes), pos = 3, cex = 0.8, col = "blue"))

# other method for volcano plot
BiocManager::install("EnhancedVolcano")
library(EnhancedVolcano)

EnhancedVolcano(deg_results,
                lab = rownames(deg_results),
                x = 'logFC',
                y = 'P.Value',
                pCutoff = 0.05,
                FCcutoff = 1,
                pointSize = 2.0,
                labSize = 3.0,
                title = 'Tumor vs Normal',
                subtitle = "DEG Volcano Plot",
                caption = "log2FC cutoff = 1; p < 0.05",
                colAlpha = 0.6,
                legendPosition = 'right',
                drawConnectors = TRUE
)
